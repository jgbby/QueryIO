{
  "manifest_version": 3,
  "name": "QueryIO",
  "version": "1.8",
  "action": {
    "default_icon": "img/icon.png",
    "default_popup": "popup.html",
    "default_title": "QueryIO"
  },
  "icons": {
    "128": "img/icon128.png",
    "48": "img/icon48.png",
    "32": "img/icon32.png",
    "16": "img/icon16.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self';"
  },
  "background": {
    "service_worker": "js/background.js"
  }
}
